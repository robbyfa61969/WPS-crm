{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user (Manager or technician)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["manager", "technician"] }
      },
      "required": ["uid", "email", "role"]
    },
    "Client": {
      "title": "Client",
      "description": "Water pump client information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["name"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Service appointment details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "technicianId": { "type": "string" },
        "technicianName": { "type": "string" },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["scheduled", "in-progress", "completed", "cancelled"] },
        "description": { "type": "string" },
        "report": { "type": "string" },
        "photoUrls": { "type": "array", "items": { "type": "string" } },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "scheduledAt", "status"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "clients/{clientId}": {
      "schema": "Client",
      "description": "Client database"
    },
    "appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Appointment records"
    }
  }
}
